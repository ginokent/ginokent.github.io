# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=
# Slack App-Level Token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=
# 監視対象の Slack チャンネル ID
SLACK_CHANNEL_ID=
# (任意) scrap に付与するデフォルトタグ (カンマ区切りで複数指定可、未設定時はタグなし)
#DEFAULT_TAGS=思ったこと,slack
# (任意) scrap 作成時に git commit push までおこなうかどうか (未設定時は git commit push をスキップ)
GIT_AUTO_COMMIT_PUSH=false
# (任意) scrap 作成・更新後にスレッドへ URL を返信する (未設定時はスレッド返信をスキップ)
SITE_URL=https://ginokent.github.io
