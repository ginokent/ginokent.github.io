---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { locales, type Locale, translations, localePath } from '../../lib/i18n';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = translations[lang];

const links = [
  { name: "GitHub", url: "https://github.com/ginokent" },
  { name: "X", url: "https://x.com/ginokentdev" },
  { name: "Blog", url: "https://ginokent.github.io" },
  { name: "Speaking experience: Google Cloud Next Tokyo 25", url: "https://www.youtube.com/watch?v=hce7t-Mxzfc" },
];
---

<BaseLayout title={t.about} description="ginokent について" lang={lang} canonicalPath={localePath('/about', lang)}>
  <div class="about">
    <img src="/ginokent.png" alt="ginokent" class="about-avatar" />
    <div class="about-content">
      <h1 class="about-name">ginokent</h1>
      <p class="about-bio">
        SRE, Software Developer, Reliable infrastructure that meets business requirements, Hourly wage from 12,000 JPY
      </p>
    </div>
  </div>

  <section class="links-section">
    <h2 class="links-title">Links</h2>
    <ul class="links-list">
      {links.map(link => (
        <li class="links-item">
          <a href={link.url} target="_blank" rel="noopener noreferrer">
            <span class="links-name">{link.name}</span>
            <span class="links-url">{link.url.replace(/^https?:\/\//, '')}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .about {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    max-width: 480px;
  }

  .about-avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .about-content {
    flex: 1;
  }

  .about-name {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .about-bio {
    color: var(--text-secondary);
    line-height: 1.6;
  }

  @media (max-width: 480px) {
    .about {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }

  .links-section {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .links-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .links-list {
    list-style: none;
  }

  .links-item {
    border-bottom: 1px solid var(--border);
  }

  .links-item:last-child {
    border-bottom: none;
  }

  .links-item a {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.625rem 0;
    color: var(--text);
    transition: color 0.2s;
  }

  .links-item a:hover {
    color: var(--accent);
  }

  .links-name {
    font-weight: 500;
    flex-shrink: 0;
  }

  .links-url {
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .links-item a:hover .links-url {
    color: var(--accent);
  }
</style>
